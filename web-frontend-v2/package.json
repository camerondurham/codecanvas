{
	"name": "web-frontend-v2",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:local-api": "PUBLIC_API_BASE_URL=http://localhost:10100 vite dev",
		"dev:prod-api": "PUBLIC_API_BASE_URL=https://runner.fly.dev vite dev",
		"build": "vite build",
		"build:pages": "PUBLIC_API_BASE_URL=https://runner.fly.dev PUBLIC_HIDE_API_TARGET_SELECTOR=true vite build",
		"preview": "vite preview",
		"preview:pages": "PUBLIC_API_BASE_URL=https://runner.fly.dev PUBLIC_HIDE_API_TARGET_SELECTOR=true vite build && vite preview --host 127.0.0.1 --port 4173",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:smoke": "playwright test",
		"test:smoke:headed": "playwright test --headed",
		"test:smoke:nix": "nix shell nixpkgs#chromium --command bash -lc 'PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=$(command -v chromium) playwright test'"
	},
	"devDependencies": {
		"@playwright/test": "^1.55.1",
		"@sveltejs/adapter-static": "^3.0.8",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"svelte": "^5.49.2",
		"svelte-check": "^4.3.6",
		"typescript": "^5.9.3",
		"vite": "^7.3.2"
	}
}
